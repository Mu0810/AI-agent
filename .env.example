# ===== AI Provider =====
AI_PROVIDER=groq          # groq | ollama
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
AI_MODEL=llama-3.3-70b-versatile

# ===== Server =====
PORT=8000
FRONTEND_URL=https://your-app.vercel.app

# ===== Database =====
# For local dev (SQLite) — leave DATABASE_URL unset
DATABASE_PATH=backend/nexus.db
# For Heroku (Postgres) — Heroku auto-sets this, no action needed
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# ===== Security =====
PRODUCTION=true
